{
  "id": "arch-updater",
  "name": "Arch Updater",
  "version": "2.1.10",
  "minNoctaliaVersion": "3.6.0",
  "author": "Ast",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "A plugin to manage updates on Arch",
  "tags": ["Bar", "Desktop", "Panel", "Launcher", "System", "Utility"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml",
    "launcherProvider": "LauncherProvider.qml",    
    "controlCenterWidget": "ControlCenterWidget.qml",
    "desktopWidget": "DesktopWidget.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "systemCmd": "checkupdates 2>/dev/null",
      "aurCmd": "paru -Qua 2>/dev/null",
      "updateCmd": "ghostty -e bash -c 'echo \"Updating System...\";paru; flatpak update; read -n 1 -p \"Press any key to exit...\"'",
      "aurHomepageCmd": "LC_ALL=C paru -Si {id} 2>/dev/null | awk '/^URL/ {print $3}'",
      "flatpak": true,
      "noctalia": true,
      "toast": true,
      "desktopTip": true,
      "hideOnEmpty": false,
      "refreshTimer": true,
      "refreshInterval": 120,
      "iconName": "arrow-big-down-lines",
      "useDistroLogo": false,
      "customIconPath": "",
      "boldText": true,
      "enableColorization": false,
      "iconColor": "none",
      "boldVer": true,
      "tooltip": true,
      "closeButton": true,
      "closeOnSettings": false,
      "panelTooltip": true,
      "panelContext": true,
      "boldVerPanel": true,
      "boldVerDesktop": true,
      "hoverTip": true
    }
  }
}
