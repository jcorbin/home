function print_dcs
{
  print -n -- "\EP$1;\E$2\E\\"
}

# Set the cursor shape via DECSCUSR (CSI Ps SP q)
#   Ps: 1 blink block
#       2 steady block
#       3 blink underline
#       4 steady underline
#       5 blink bar
#       6 steady bar
function set_cursor_shape
{
  if [ -n "$TMUX" ]; then
    # tmux will only forward escape sequences to the terminal if surrounded by
    # a DCS sequence
    print_dcs tmux "\E[$1 q"
  else
    print -n -- "\E[$1 q"
  fi
}

function zle-keymap-select zle-line-init
{
  case $KEYMAP in
    vicmd)
      set_cursor_shape 2 # steady block
      ;;
    viins|main)
      set_cursor_shape 6 # steady bar
      ;;
  esac
  zle reset-prompt
  zle -R
}

function zle-line-finish
{
  set_cursor_shape 2 # steady block
}

zle -N zle-line-init
zle -N zle-line-finish
zle -N zle-keymap-select

