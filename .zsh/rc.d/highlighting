#!/bin/zsh
# after: completion
# after: compose
# after: editor
# after: history
# after: vi-mode-cursor
# after: autosuggestions

# zsh-syntax-highlighting must be sourced LAST, after every widget is defined
# (that's why all the `# after:` deps above, incl. autosuggestions).
# Prefer the pacman package; fall back to a local clone if one exists.
zsh_hl=
for cand in \
    /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
    ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
do
    if [ -f "$cand" ]; then zsh_hl="$cand"; break; fi
done

if [ -n "$zsh_hl" ]; then
    source "$zsh_hl"
    unset zsh_hl

    # main = command/argument coloring; brackets = matching-bracket highlight.
    ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)

    ZSH_HIGHLIGHT_STYLES[default]=none
    ZSH_HIGHLIGHT_STYLES[unknown-token]=fg=131,bold
    ZSH_HIGHLIGHT_STYLES[reserved-word]=fg=034
    ZSH_HIGHLIGHT_STYLES[alias]=fg=178
    ZSH_HIGHLIGHT_STYLES[builtin]=fg=178
    ZSH_HIGHLIGHT_STYLES[function]=fg=178
    ZSH_HIGHLIGHT_STYLES[command]=fg=178
    ZSH_HIGHLIGHT_STYLES[precommand]=fg=103
    ZSH_HIGHLIGHT_STYLES[commandseparator]=fg=034
    ZSH_HIGHLIGHT_STYLES[hashed-command]=fg=178
    ZSH_HIGHLIGHT_STYLES[path]=fg=065
    ZSH_HIGHLIGHT_STYLES[globbing]=fg=067
    ZSH_HIGHLIGHT_STYLES[history-expansion]=fg=075
    ZSH_HIGHLIGHT_STYLES[single-hyphen-option]=fg=067
    ZSH_HIGHLIGHT_STYLES[double-hyphen-option]=fg=067
    ZSH_HIGHLIGHT_STYLES[back-quoted-argument]=fg=178
    ZSH_HIGHLIGHT_STYLES[single-quoted-argument]=fg=065
    ZSH_HIGHLIGHT_STYLES[double-quoted-argument]=fg=065
    ZSH_HIGHLIGHT_STYLES[dollar-double-quoted-argument]=fg=067
    ZSH_HIGHLIGHT_STYLES[back-double-quoted-argument]=fg=044
    ZSH_HIGHLIGHT_STYLES[assign]=fg=178
fi

