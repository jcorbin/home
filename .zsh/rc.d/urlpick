#!/bin/zsh
# after: editor
# after: fzf
# after: autosuggestions
#
# One-keystroke, mouse-free URL opener for ghostty (replaces alacritty's
# Ctrl+Shift+O hint mode). Ghostty 1.3.x has no native URL-hint action and
# can't run a script from a keybind, so we bridge through its scrollback dump:
#
#   Ctrl+Shift+O  (see ~/.config/ghostty/config) = write_scrollback_file:paste
#   -> ghostty writes the scrollback to a fresh temp file and *pastes that
#      file's path* onto the prompt. The bracketed-paste hook below spots that
#      paste (empty line + a lone, absolute, just-created readable file) and
#      turns it into `urls <path>` on the spot. One key, done.
#
# The hook fires on paste itself, so it's immune to vi-mode / ESC-prefix
# keymap trouble. Every ordinary paste falls straight through untouched.
#
# `urls` is also useful on its own:
#   somecmd | urls        # pick a URL out of a pipe
#   urls FILE             # pick a URL out of a file

urls() {
    emulate -L zsh

    local text
    if (( $# )); then
        [[ -r $1 ]] || { print -u2 "urls: cannot read '$1'"; return 1; }
        text=$(<"$1")
    elif [[ ! -t 0 ]]; then
        text=$(cat)                        # piped input
    else
        print -u2 "urls: no file/pipe given. (Ctrl+Shift+O does this for you.)"
        return 1
    fi

    # Pull http(s)/ftp/file URLs, trim trailing punctuation, de-dupe (stable order).
    local -a found
    found=(${(f)"$(print -r -- "$text" \
        | grep -oiE '(https?|ftp|file)://[^[:space:]<>"'\''`|]+' \
        | sed -E 's/[])>.,;:!?'\''"]+$//' \
        | awk 'NF && !seen[$0]++')"})

    if (( ! ${#found} )); then
        print -u2 "urls: no URLs found."
        return 1
    fi

    local picks
    picks=$(print -rl -- "${found[@]}" \
        | fzf --multi --no-sort --reverse --height=60% --border \
              --prompt='open url> ') || return 0
    [[ -n $picks ]] || return 0

    local u
    while IFS= read -r u; do
        [[ -n $u ]] || continue
        uwsm app -- xdg-open "$u" >/dev/null 2>&1 \
            || xdg-open "$u" >/dev/null 2>&1
    done <<< "$picks"
}

# --- Fuse ghostty's scrollback-dump paste into a URL pick (one keystroke) ---
zmodload zsh/datetime         2>/dev/null   # $EPOCHSECONDS
zmodload -F zsh/stat b:zstat  2>/dev/null   # zstat -> file mtime

# Chain to whatever bracketed-paste handler is already installed (e.g. the one
# zsh-autosuggestions sets up), so we augment it instead of replacing it.
typeset -g _urls_prev_bp="${widgets[bracketed-paste]}"

_urls_bracketed_paste() {
    emulate -L zsh
    local before=$BUFFER

    # Run the real paste first.
    if [[ $_urls_prev_bp == user:* ]]; then
        zle "${_urls_prev_bp#user:}"
    else
        zle .bracketed-paste
    fi

    # Only consider fusing when the line started empty.
    [[ -n $before ]] && return 0

    # The paste must be exactly one shell token (a lone path, no spaces).
    local -a words
    words=( ${(z)BUFFER} )
    (( ${#words} == 1 )) || return 0
    local p=${words[1]}

    # ...an absolute path to an existing readable regular file...
    [[ $p == /* && -f $p && -r $p ]] || return 0

    # ...that ghostty just wrote (guards against pasting some old file path).
    local -a st
    zstat -A st +mtime -- $p 2>/dev/null || return 0
    (( ${+EPOCHSECONDS} )) && (( EPOCHSECONDS - st[1] > 10 )) && return 0

    # It's a fresh scrollback dump: run the picker as a normal foreground
    # command (where fzf owns the tty cleanly).
    BUFFER="urls ${(q)p}"
    zle accept-line
}
zle -N bracketed-paste _urls_bracketed_paste

